{
  "name": "@manohar_maharshi/genoid",
  "version": "1.18.0",
  "description": "GenoID — a declarative RFC 9562 v8 UUID library: GA-inspired pooled-CSPRNG generation plus structured layouts (shard, tenant, counter, timestamp) with constraint-guided repair, no rejection sampling",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/algo.js",
    "dist/algo.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "bun test scripts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "ultracite fix",
    "format:check": "ultracite check",
    "bench": "bun run scripts/bench.ts",
    "bench-ci": "bun run scripts/bench-ci.ts",
    "bench-concurrent": "bun run scripts/bench-concurrent.ts",
    "bench-sqlite": "bun run scripts/bench-sqlite.ts",
    "collision-100m": "bun run scripts/collision-100m.ts",
    "export-dieharder": "bun run scripts/export-dieharder.ts",
    "dieharder": "bun run scripts/run-dieharder.ts",
    "test:stats": "bun run scripts/stats.ts",
    "playwright": "tsx scripts/playwright.ts",
    "verify-playwright": "tsx scripts/playwright.dryrun.ts",
    "publish": "bun run build && bun publish",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.1.0",
    "oxlint": "^1.74.0",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "7.0.2",
    "ultracite": "^7.9.4"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
